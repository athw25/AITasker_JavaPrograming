+    private final JwtHandshakeChannelInterceptor jwtHandshakeChannelInterceptor;
+
+    // Trước là "*" (mọi origin) — thu hẹp lại qua cấu hình để tránh CSWSH
+    // (Cross-Site WebSocket Hijacking). Đặt CORS_ALLOWED_ORIGINS trong env
