# Copy file này thành .env (đã có trong .gitignore) và điền giá trị thật.
# KHÔNG commit file .env vào git.

DB_URL=jdbc:sqlserver://127.0.0.1:1433;databaseName=AITasker;encrypt=false;trustServerCertificate=true
DB_USERNAME=sa
DB_PASSWORD=your_sql_server_password

# Sinh secret mới, tối thiểu 32 ký tự, KHÔNG dùng lại secret cũ đã từng
# bị commit vào git (secret đó coi như đã lộ, phải thay secret khác).
JWT_SECRET=replace_with_a_new_random_secret_at_least_32_chars
JWT_EXPIRATION_MS=86400000

# Danh sách origin được phép gọi API / kết nối WebSocket, phân tách bởi dấu phẩy
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
