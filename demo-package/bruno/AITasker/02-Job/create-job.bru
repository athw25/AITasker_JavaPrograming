meta {
  name: Create Job
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/jobs
  body: json
  auth: bearer
}

auth:bearer {
  token: {{clientToken}}
}

body:json {
  {
    "title": "Bruno Test Job",
