meta {
  name: Create Milestone
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/milestones
  body: json
  auth: bearer
}

auth:bearer {
  token: {{clientToken}}
}

body:json {
  {
    "projectId": {{projectId}},
    "title": "Bruno Test Milestone",
    "description": "Milestone tao qua Bruno",
    "amount": 900.00,
    "dueDate": "2026-07-20"
  }
}

script:post-response {
  bru.setVar("milestoneId", res.body.data ? res.body.data.id : res.body.id);
}
